<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".p2Activity">

    <TextView
        android:id="@+id/practice1_banner"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="top"
        android:layout_marginTop="10dp"
        android:background="#CCB287FD"
        android:gravity="center_horizontal|center_vertical"
        android:text="@string/go_p2"
        android:textSize="50sp"
        android:textStyle="bold"></TextView>
    <Button
        android:id="@+id/btBTN"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center_horizontal|center_vertical"
        android:layout_margin="20dp"
        android:background="@drawable/selector_bt_btn"
        android:onClick="clickFunc">

    </Button>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:text="초음파"
            android:background="#2F1E1E1E"
            android:gravity="center_horizontal|center_vertical"
            android:textColor="#141414"
            android:textSize="30sp"
            android:textStyle="bold"></TextView>

        <TextView
            android:id="@+id/p5_display"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:background="#FFEB3B"
            android:gravity="center_horizontal|center_vertical"
            android:textColor="#141414"
            android:textSize="30sp"
            android:textStyle="bold"></TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="20dp"
            android:text="조도"
            android:layout_weight="1"
            android:background="#2F1E1E1E"
            android:gravity="center_horizontal|center_vertical"
            android:textColor="#141414"
            android:textSize="30sp"
            android:textStyle="bold"></TextView>

        <TextView
            android:id="@+id/p2_cds"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:background="#4CAF50"
            android:gravity="center_horizontal|center_vertical"
            android:textColor="#141414"
            android:textSize="30sp"
            android:textStyle="bold"></TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:text="가변저항"
            android:background="#2F1E1E1E"
            android:gravity="center_horizontal|center_vertical"
            android:textColor="#141414"
            android:textSize="30sp"
            android:textStyle="bold"></TextView>
        <TextView
            android:id="@+id/p2_poten"
            android:layout_width="match_parent"
            android:textSize="30sp"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textColor="#141414"
            android:layout_height="80dp"
            android:layout_margin="20dp"
            android:gravity="center_horizontal|center_vertical"
            android:background="#1E88E5">
        </TextView>
    </LinearLayout>
</LinearLayout>
