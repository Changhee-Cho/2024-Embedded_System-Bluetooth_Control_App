<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".p2Activity">

    <TextView
        android:id="@+id/practice1_banner"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="top"
        android:layout_marginTop="10dp"
        android:background="#00BCD4"
        android:gravity="center_horizontal|center_vertical"
        android:text="실습 4번"
        android:textSize="50sp"
        android:textStyle="bold"></TextView>

    <Button
        android:id="@+id/btBTN"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center_horizontal|center_vertical"
        android:layout_margin="20dp"
        android:background="@drawable/selector_bt_btn"
        android:onClick="clickFunc">
    </Button>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/p4_do"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='도'
            android:textSize="20sp"></Button>

        <Button
            android:id="@+id/p4_re"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='레'
            android:textSize="20sp"></Button>

        <Button
            android:id="@+id/p4_mi"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='미'
            android:textSize="20sp"></Button>
        <Button
            android:id="@+id/p4_fa"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='파'
            android:textSize="20sp"></Button>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/p4_sol"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='솔'
            android:textSize="20sp"></Button>

        <Button
            android:id="@+id/p4_la"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='라'
            android:textSize="20sp"></Button>

        <Button
            android:id="@+id/p4_ti"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='시'
            android:textSize="20sp"></Button>
        <Button
            android:id="@+id/p4_end"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='끝'
            android:textSize="20sp"></Button>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/p4_rabbit"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='산토끼'
            android:textSize="20sp"></Button>

        <Button
            android:id="@+id/p4_star"
            android:layout_width="wrap_content"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|center_horizontal"
            android:layout_margin="20dp"
            android:layout_weight="1"
            android:onClick="clickFunc"
            android:text='작은별'
            android:textSize="20sp"></Button>

    </LinearLayout>
</LinearLayout>
